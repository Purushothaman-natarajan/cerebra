# =============================================================================
# Cerebra-AI Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All fields have sensible defaults for local development.

# --- LLM Provider ---
# Google Gemini API key for LLM inference. Required for any LLM call.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Telegram Bot (optional) ---
# Bot token for Telegram channel integration.
# Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL where Telegram sends webhook events.
# Use https://your-domain.com/channels/webhook/telegram (requires TLS).
TELEGRAM_WEBHOOK_URL=

# --- Database ---
# PostgreSQL with asyncpg driver (production). Use sqlite+aiosqlite for local dev.
# Examples:
#   postgresql+asyncpg://user:pass@localhost:5432/cerebra
#   sqlite+aiosqlite:///./orchid.db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cerebra

# --- Redis ---
# Connection string for event bus pub/sub.
# Password is injected automatically from REDIS_PASSWORD if set.
REDIS_URL=redis://:password@localhost:6379/0
REDIS_PASSWORD=

# --- CORS ---
# Comma-separated list of allowed origins for browser requests.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- API Auth ---
# API key for Bearer-token authentication.
# If empty, all requests pass through (dev mode).
# Set to a strong random value in production.
CEREBRA_API_KEY=

# --- Encryption ---
# Secret key for encrypting provider API keys at rest.
# Must be at least 16 characters. Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# If empty, API keys are stored in plaintext (dev mode only!).
ENCRYPTION_KEY=

# --- Connection Pooling ---
# Number of persistent database connections.
DB_POOL_SIZE=5
# Maximum additional connections beyond the pool size during bursts.
DB_MAX_OVERFLOW=10

# --- Observability ---
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Service name for structured log records
SERVICE_NAME=cerebra-backend
